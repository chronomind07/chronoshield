{
  "manifest_version": 3,
  "name": "ChronoShield — Phishing Detector",
  "version": "1.0.0",
  "description": "Detecta phishing en Gmail en tiempo real. Analiza remitentes, dominios y enlaces sospechosos.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://chronoshield-production.up.railway.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ChronoShield",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
